import cv2
import numpy as np

# Read the image from the specified path
image = cv2.imread(r"C:\Users\nagin\Downloads\OIP (2).jpg")

# Get image dimensions
rows, cols, ch = image.shape

# Define points for the affine transformation
pts1 = np.float32([[50, 50], [200, 50], [50, 200]])
pts2 = np.float32([[10, 100], [200, 50], [100, 250]])

# Compute the affine transformation matrix
matrix = cv2.getAffineTransform(pts1, pts2)

# Apply the affine transformation
transformed_image = cv2.warpAffine(image, matrix, (cols, rows))

# Display the images
cv2.imshow("Original Image", image)
cv2.imshow("Affine Transformed Image", transformed_image)

# Save the transformed image
cv2.imwrite(r"C:\Users\nagin\Downloads\affine_transformed.jpg", transformed_image)

cv2.waitKey(0)
cv2.destroyAllWindows()
